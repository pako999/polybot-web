# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key
CLERK_SECRET_KEY=sk_test_your_key
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_clerk_webhook_secret

# Frontend API base URL (empty = same origin)
NEXT_PUBLIC_API_BASE_URL=

# Telegram admin notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Shared secret for VPS error/down alerts -> /api/ops/alert
OPS_ALERT_TOKEN=

# Optional: distributed rate limit storage (Upstash Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: override CSP policy or run in report-only mode
# SECURITY_CSP=default-src 'self'; ...
SECURITY_CSP_REPORT_ONLY=true
SECURITY_CSP_REPORT_ENDPOINT=/api/csp/report

# Internal bot bridge (server-side only; never expose with NEXT_PUBLIC_)
POLYBOT_INTERNAL_BASE_URL=https://bot.polybot.uk
POLYBOT_INTERNAL_API_TOKEN=

# Optional: comma-separated Clerk user IDs allowed to access /admin
ADMIN_USER_IDS=
