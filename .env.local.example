# ============================================
# CLERK AUTHENTICATION
# ============================================
# Get these from https://dashboard.clerk.com
# Create a new application → choose your sign-in methods
# (email, Google, GitHub, etc.)
#
# 1. Go to dashboard.clerk.com
# 2. Create application → name it "PolyBot"
# 3. Choose sign-in methods (Email, Google, GitHub recommended)
# 4. Copy the keys below from API Keys section
# ============================================

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sign-in / Sign-up URLs (must match app routing)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup

# Where to redirect after sign-in / sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================
# BOT API (your VPS IP — so dashboard can fetch live data)
# ============================================
NEXT_PUBLIC_BOT_API_URL=http://YOUR_VPS_IP:8899

# ============================================
# STRIPE (add later for payments)
# ============================================
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
